# SignalStream Environment Configuration

# --- Required ---
JWT_SECRET="your-jwt-secret-at-least-16-chars"
ENCRYPTION_KEY="exactly-32-bytes-for-aes256!!"

# --- API Keys (optional if users provide via UI) ---
POLYGON_API_KEY="your_polygon_key_here"
OPENAI_API_KEY="sk-your_openai_key_here"

# --- Database ---
DATABASE_URL="postgres://signalstream:dev_password@localhost:5432/signalstream"

# --- Qdrant ---
QDRANT_HOST="127.0.0.1"
QDRANT_PORT=6334

# --- Server ---
SERVER_PORT=8080
FRONTEND_URL="http://localhost:3000"
LOG_LEVEL="info"
